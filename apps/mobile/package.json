{
  "name": "@sparqplug/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build:ios:internal": "eas build --platform ios --profile preview",
    "build:ios:testflight": "eas build --platform ios --profile production",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "submit:ios:testflight": "eas submit --platform ios --profile production",
    "release:ios:testflight": "eas build --platform ios --profile production --auto-submit",
    "ota:update:internal": "eas update --branch preview --message \"Internal iOS OTA update\"",
    "ota:update:production": "eas update --branch production --message \"Production iOS OTA update\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@expo/metro-runtime": "^56.0.14",
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native/assets-registry": "0.74.87",
    "@react-navigation/bottom-tabs": "^6.6.0",
    "@sparqplug/types": "workspace:*",
    "@tanstack/react-query": "^5.59.0",
    "expo": "~51.0.0",
    "expo-asset": "~10.0.10",
    "expo-clipboard": "~6.0.3",
    "expo-constants": "~16.0.0",
    "expo-font": "~12.0.0",
    "expo-haptics": "~13.0.0",
    "expo-linking": "~6.3.0",
    "expo-local-authentication": "~14.0.1",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.0",
    "expo-splash-screen": "~0.27.0",
    "expo-status-bar": "~1.12.0",
    "firebase": "^10.13.0",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.0",
    "babel-preset-expo": "^56.0.14",
    "typescript": "~5.3.3"
  }
}

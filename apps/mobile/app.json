{
  "expo": {
    "name": "SparQPlug",
    "slug": "sparqplug",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sparqplug",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0f1e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sparqplug.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to unlock client passwords in SparQPlug Password Locker."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0a0f1e"
      },
      "package": "com.sparqplug.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to unlock client passwords in SparQPlug Password Locker."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a0f1e"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

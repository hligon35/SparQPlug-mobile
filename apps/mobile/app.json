{
  "expo": {
    "name": "SparQPlug",
    "slug": "sparqplug",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/sparqplugIcon.png",
    "scheme": "sparqplug",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0f1e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sparqplug.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to unlock client passwords in SparQPlug Password Locker.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/sparqplugIcon.png",
        "backgroundColor": "#0a0f1e"
      },
      "package": "com.sparqplug.app",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/sparqplugIcon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to unlock client passwords in SparQPlug Password Locker."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a0f1e"
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "4558c317-f31b-45e1-9b38-58c734947a75"
      }
    }
  }
}

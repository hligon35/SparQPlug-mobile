# SparQPlug Environment Variables Template
# Copy this to .env.local and fill in your values

# ============================================
# FIREBASE AUTHENTICATION
# ============================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ============================================
# CLOUDFLARE
# ============================================
VITE_API_BASE_URL=https://api.sparqplug.workers.dev
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ============================================
# STRIPE
# ============================================
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# APP CONFIG
# ============================================
VITE_APP_NAME=SparQPlug
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# ============================================
# CLOUDFLARE D1 (for wrangler)
# ============================================
D1_DATABASE_ID=

# ============================================
# BOOTSTRAP ADMIN SETUP (one-time use)
# Run: pnpm bootstrap after setting these
# ============================================
BOOTSTRAP_SECRET=change_me_to_a_long_random_secret
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change_me_strong_password
ADMIN_NAME=Admin User
ADMIN_ORG_NAME=SparQPlug
FIREBASE_API_KEY=          # same as VITE_FIREBASE_API_KEY above

D1_DATABASE_NAME=sparqplug-db

# ============================================
# CLOUDFLARE R2
# ============================================
R2_BUCKET_NAME=sparqplug-files
R2_PUBLIC_URL=

{
  "name": "@sparqplug/backend",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:remote": "wrangler d1 migrations apply sparqplug-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply sparqplug-db --local",
    "db:studio": "drizzle-kit studio",
    "db:push": "wrangler d1 execute sparqplug-db --local --file=./drizzle/schema.sql"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.0",
    "@sparqplug/types": "workspace:*",
    "drizzle-orm": "^0.33.0",
    "hono": "^4.5.0",
    "jose": "^5.9.0",
    "stripe": "^16.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240924.0",
    "drizzle-kit": "^0.24.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.95.0"
  }
}
